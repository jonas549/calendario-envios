// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model City {
  id          String   @id @default(cuid())
  shop        String
  name        String
  cutoffTime  String
  days        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shop, name])
  @@index([shop])
}

model Holiday {
  id        String   @id @default(cuid())
  shop      String
  date      DateTime
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([shop])
}

model Config {
  id                 String   @id @default(cuid())
  shop               String   @unique
  mode               String   @default("mismo_dia")
  daysAhead          Int      @default(1)
  additionalMessage  String   @default("")
  updatedAt          DateTime @updatedAt

  @@index([shop])
}
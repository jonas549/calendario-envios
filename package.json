{
  "name": "calendario-envios-app",
  "private": true,
  "type": "module",
  "author": "Jonas",

  "scripts": {
    "build": "react-router build",

    "vercel-build": "prisma generate && prisma db push --accept-data-loss && react-router build",

    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "react-router-serve ./build/server/index.js",
    "docker-start": "npm run setup && npm run start",
   
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "typecheck": "react-router typegen && tsc --noEmit"
  },

  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },

  "dependencies": {
    "@react-router/dev": "7.9.5",
    "@react-router/fs-routes": "7.9.5",
    "@react-router/node": "7.9.5",
    "@react-router/serve": "7.9.5",
    "@remix-run/node": "2.17.2",
    "@remix-run/react": "2.17.2",
    "@remix-run/server-runtime": "2.17.2",
    "@remote-ui/react": "5.0.8",
    "@shopify/app-bridge-react": "4.2.4",
    "@shopify/polaris": "^12.5.0",
    "@shopify/shopify-app-react-router": "^1.0.2",
    "@shopify/shopify-app-session-storage-prisma": "7.0.0",
    "@shopify/ui-extensions": "2025.7.1",
    "@shopify/ui-extensions-react": "2025.7.1",
    "date-fns": "4.1.0",
    "isbot": "5.1.31",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-reconciler": "0.29.2",
    "react-router": "7.9.5",
    "react-router-dom": "7.9.5",
    "vite-tsconfig-paths": "5.1.4"
  },

  "devDependencies": {
    "@prisma/client": "6.19.0",
    "@shopify/api-codegen-preset": "1.2.0",
    "@shopify/polaris-types": "1.0.1",
    "@types/eslint": "9.6.1",
    "@types/node": "22.18.8",
    "@types/react": "18.3.25",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "eslint": "8.57.1",
    "eslint-import-resolver-typescript": "3.10.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "4.6.2",
    "graphql-config": "5.1.1",
    "prettier": "3.6.2",
    "prisma": "6.19.0",
    "typescript": "5.9.3",
    "vite": "6.3.6"
  },

  "workspaces": ["extensions/*"],

  "trustedDependencies": ["@shopify/plugin-cloudflare"],

  "overrides": {
    "p-map": "4.0.0"
  }
}

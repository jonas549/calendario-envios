<div id="calendify-app-block" data-shop="{{ shop.permanent_domain }}">
  <!-- El calendario se inyectará aquí -->
</div>

<script>
  (function() {
    const shop = "{{ shop.permanent_domain }}";
    const scriptUrl = "https://calendario-envios.vercel.app/apps/proxy/api/script?shop=" + encodeURIComponent(shop);
    
    const script = document.createElement('script');
    script.src = scriptUrl;
    script.async = true;
    document.body.appendChild(script);
  })();
</script>

{% schema %}
{
  "name": "Calendario de Entregas",
  "target": "section",
  "templates": ["cart"],
  "settings": [
    {
      "type": "paragraph",
      "content": "Este bloque muestra el calendario para seleccionar fecha y ciudad de entrega."
    }
  ],
  "presets": [
    {
      "name": "Calendario de Entregas"
    }
  ]
}
{% endschema %}
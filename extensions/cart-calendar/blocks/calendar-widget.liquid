{% comment %}
  Calendify Delivery — App Block posicionable
  Funciona en carrito, producto, o cualquier sección del tema.
  El merchant lo arrastra desde Personalizar tema → Apps.
{% endcomment %}

{% assign wid = block.id | remove: '-' %}

<style>
  #ce-widget-{{ wid }} .ce-date-trigger {
    display: flex;
    align-items: center;
    border: 1px solid #ccc;
    border-radius: 4px;
    cursor: pointer;
    background: #fff;
    transition: border-color 0.2s;
    user-select: none;
  }
  #ce-widget-{{ wid }} .ce-date-trigger:hover { border-color: #555; }
  #ce-widget-{{ wid }} .ce-date-trigger.ce-open { border-color: #0066cc; }
  #ce-widget-{{ wid }} .ce-date-display {
    flex: 1;
    padding: 10px 12px;
    font-size: 14px;
    color: #333;
  }
  #ce-widget-{{ wid }} .ce-date-display.ce-placeholder { color: #aaa; }
  #ce-widget-{{ wid }} .ce-cal-arrow {
    padding: 10px 12px;
    color: #888;
    font-size: 11px;
  }
  #ce-widget-{{ wid }} .ce-cal-panel {
    border: 1px solid #e0e0e0;
    border-top: none;
    border-radius: 0 0 4px 4px;
    overflow: hidden;
    background: #fff;
  }
  #ce-widget-{{ wid }} .ce-message {
    padding: 11px 14px;
    border-radius: 6px;
    font-size: 14px;
    margin-top: 10px;
    border-left: 4px solid transparent;
    display: none;
  }
  #ce-widget-{{ wid }} .ce-message.ce-success {
    background: #e8f5e9;
    color: #1b5e20;
    border-left-color: #43a047;
    font-weight: 600;
    font-size: 15px;
  }
  #ce-widget-{{ wid }} .ce-message.ce-warning {
    background: #fff3cd;
    color: #856404;
    border-left-color: #ffc107;
  }
  #ce-widget-{{ wid }} .ce-message.ce-error {
    background: #ffebee;
    color: #c62828;
    border-left-color: #ef5350;
  }
  #ce-widget-{{ wid }} .ce-message.ce-loading {
    background: #f0f0f0;
    color: #555;
    border-left-color: #ccc;
  }
</style>

<div id="ce-widget-{{ wid }}" class="ce-wrapper">

  {% if block.settings.show_title %}
  <h3 style="margin: 0 0 15px 0; font-size: 18px;">
    {{ block.settings.widget_title | default: '📅 Selecciona tu fecha de entrega' }}
  </h3>
  {% endif %}

  <!-- Opción de recogida (visible solo si pickupEnabled en admin) -->
  <div id="ce-pickup-section-{{ wid }}" style="display: none; margin-bottom: 15px;">
    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 14px; font-weight: 500;">
      <input type="checkbox" id="ce-pickup-{{ wid }}" style="width: 16px; height: 16px; cursor: pointer;">
      <span id="ce-pickup-label-{{ wid }}">Recoger en tienda</span>
    </label>
  </div>

  <!-- Sección de entrega a domicilio -->
  <div id="ce-delivery-{{ wid }}" class="ce-fields">

    <div class="ce-field">
      <label for="ce-city-{{ wid }}">Ciudad</label>
      <select id="ce-city-{{ wid }}">
        <option value="">-- Selecciona tu ciudad --</option>
      </select>
    </div>

    <!-- Selector de fecha: trigger clickeable + panel colapsable -->
    <div id="ce-date-wrapper-{{ wid }}" class="ce-field" style="display: none;">
      <label>Fecha de entrega</label>
      <!-- Trigger clickeable que muestra la fecha seleccionada -->
      <div id="ce-date-trigger-{{ wid }}" class="ce-date-trigger" role="button" tabindex="0" aria-expanded="false">
        <span id="ce-date-display-{{ wid }}" class="ce-date-display ce-placeholder">Toca para ver fechas disponibles</span>
        <span id="ce-cal-arrow-{{ wid }}" class="ce-cal-arrow">&#9660;</span>
      </div>
      <!-- Input oculto que usa flatpickr internamente -->
      <input type="text" id="ce-date-{{ wid }}" style="display: none;" aria-hidden="true">
      <!-- Panel colapsable del calendario inline -->
      <div id="ce-cal-panel-{{ wid }}" class="ce-cal-panel" style="display: none;"></div>
    </div>

  </div>

  <!-- Mensaje de estado -->
  <div id="ce-msg-{{ wid }}" class="ce-message"></div>

</div>

<link rel="stylesheet" href="{{ 'calendar.css' | asset_url }}">

<script>
// ── Selectores de detección automática (Capa 1) ───────────────
// Compartidos entre el widget principal y el modo selección visual.
var CE_AUTO_SELECTORS = [
  '[name="checkout"]',
  'button[name="checkout"]',
  'input[name="checkout"]',
  'shopify-buy-it-now-button',
  'shopify-payment-button',
  '.shopify-payment-button__button',
  '.cart__checkout-button',
  '.cart-checkout-button',
  '#CartSubmit',
  '.cart__submit',
  '.cart__checkout',
  '.cart-form__checkout',
  '[data-checkout-url]',
  '[data-action="checkout"]',
  '.product-form__buy-it-now',
  '.dynamic-checkout__content button',
  'a[href="/checkout"]',
];

// ── Widget principal ──────────────────────────────────────────
(function() {
  'use strict';

  var SHOP = {{ shop.permanent_domain | json }};
  var WID  = {{ wid | json }};
  var LSK  = 'ce_' + SHOP.replace(/\./g, '_');

  window.__ceShop = SHOP;

  var appConfig        = {};
  var fpInstance       = null;
  var deliverySelected = false;
  var pickupSelected   = false;

  // ── Helpers ───────────────────────────────────────────────────
  function $w(name) { return document.getElementById('ce-' + name + '-' + WID); }

  function showMsg(text, type) {
    var el = $w('msg');
    if (!el) return;
    el.textContent = text;
    el.className   = 'ce-message ce-' + (type || 'loading');
    el.style.display = 'block';
  }

  // ── Calendar panel ─────────────────────────────────────────────
  function openCalPanel() {
    var panel   = document.getElementById('ce-cal-panel-'   + WID);
    var trigger = document.getElementById('ce-date-trigger-' + WID);
    var arrow   = document.getElementById('ce-cal-arrow-'   + WID);
    if (panel)   panel.style.display = 'block';
    if (trigger) { trigger.classList.add('ce-open'); trigger.setAttribute('aria-expanded', 'true'); }
    if (arrow)   arrow.innerHTML = '&#9650;';
    console.log('[Calendify-Debug] calendario ABIERTO');
  }

  function closeCalPanel() {
    var panel   = document.getElementById('ce-cal-panel-'   + WID);
    var trigger = document.getElementById('ce-date-trigger-' + WID);
    var arrow   = document.getElementById('ce-cal-arrow-'   + WID);
    if (panel)   panel.style.display = 'none';
    if (trigger) { trigger.classList.remove('ce-open'); trigger.setAttribute('aria-expanded', 'false'); }
    if (arrow)   arrow.innerHTML = '&#9660;';
    console.log('[Calendify-Debug] calendario CERRADO');
  }

  function toggleCalPanel() {
    var panel = document.getElementById('ce-cal-panel-' + WID);
    if (!panel) return;
    if (panel.style.display === 'none' || !panel.style.display) {
      openCalPanel();
    } else {
      closeCalPanel();
    }
  }

  function updateDateDisplay(dateStr) {
    var el = document.getElementById('ce-date-display-' + WID);
    if (!el) return;
    if (dateStr) {
      el.textContent = dateStr;
      el.classList.remove('ce-placeholder');
    } else {
      el.textContent = 'Toca para ver fechas disponibles';
      el.classList.add('ce-placeholder');
    }
  }

  // ── Boot ─────────────────────────────────────────────────────
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

  function boot() {
    loadConfig();
    setupCheckoutInterception();

    var trigger = document.getElementById('ce-date-trigger-' + WID);
    if (trigger) {
      trigger.addEventListener('click', toggleCalPanel);
      trigger.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleCalPanel(); }
      });
    }
  }

  // ── Load cities + config ──────────────────────────────────────
  async function loadConfig() {
    try {
      var res  = await fetch('/apps/proxy/api/cities?shop=' + encodeURIComponent(SHOP));
      var data = await res.json();
      if (!data.success) return;

      populateCities(data.cities || []);
      appConfig       = data.config || {};
      window.__ceCfg  = appConfig;

      applyPickupConfig();
      $w('city').addEventListener('change', onCityChange);
      restoreFromLocalStorage();

    } catch (err) {
      showMsg('❌ Error al cargar configuración', 'error');
    }
  }

  function populateCities(cities) {
    var select = $w('city');
    cities.forEach(function(city) {
      var opt         = document.createElement('option');
      opt.value       = city.name;
      opt.textContent = city.name;
      select.appendChild(opt);
    });
  }

  // ── Pickup ────────────────────────────────────────────────────
  function applyPickupConfig() {
    if (!appConfig.pickupEnabled) return;

    var section = document.getElementById('ce-pickup-section-' + WID);
    if (section) section.style.display = 'block';

    var labelEl = document.getElementById('ce-pickup-label-' + WID);
    if (labelEl) labelEl.textContent = appConfig.pickupLabel || 'Recoger en tienda';

    var checkbox = document.getElementById('ce-pickup-' + WID);
    if (checkbox) {
      checkbox.addEventListener('change', function(e) { applyPickupState(e.target.checked); });
      if (localStorage.getItem(LSK + '_pickup') === 'true') {
        checkbox.checked = true;
        applyPickupState(true);
      }
    }
  }

  function applyPickupState(checked) {
    pickupSelected = checked;
    var deliveryDiv = document.getElementById('ce-delivery-' + WID);
    if (deliveryDiv) deliveryDiv.style.display = checked ? 'none' : 'block';

    if (checked) {
      localStorage.setItem(LSK + '_pickup', 'true');
      localStorage.removeItem(LSK + '_city');
      localStorage.removeItem(LSK + '_date');
      updateCartAttributes({ delivery_type: 'pickup', delivery_city: '', delivery_date: '' });
    } else {
      localStorage.removeItem(LSK + '_pickup');
      updateCartAttributes({ delivery_type: 'delivery' });
    }
    notifyState();
  }

  // ── City change ───────────────────────────────────────────────
  async function onCityChange() {
    var city = $w('city').value;

    if (!city) {
      if (fpInstance) { fpInstance.destroy(); fpInstance = null; }
      document.getElementById('ce-date-wrapper-' + WID).style.display = 'none';
      closeCalPanel();
      updateDateDisplay(null);
      localStorage.removeItem(LSK + '_city');
      localStorage.removeItem(LSK + '_date');
      deliverySelected    = false;
      $w('msg').style.display = 'none';
      notifyState();
      return;
    }

    showMsg('⏳ Cargando fechas disponibles...', 'loading');

    try {
      var res  = await fetch(
        '/apps/proxy/api/availability?city=' + encodeURIComponent(city) +
        '&shop=' + encodeURIComponent(SHOP)
      );
      var data = await res.json();

      if (data.success && data.availableDates && data.availableDates.length > 0) {
        document.getElementById('ce-date-wrapper-' + WID).style.display = 'block';
        initFlatpickr(city, data.availableDates);
      } else {
        document.getElementById('ce-date-wrapper-' + WID).style.display = 'block';
        closeCalPanel();
        showMsg('⚠️ No hay fechas disponibles para esta ciudad', 'warning');
      }
    } catch (err) {
      showMsg('❌ Error al cargar fechas disponibles', 'error');
    }
  }

  // ── Flatpickr ─────────────────────────────────────────────────
  function initFlatpickr(city, availableDates) {
    loadFlatpickrLib(function() {
      if (fpInstance) fpInstance.destroy();

      var savedCity   = localStorage.getItem(LSK + '_city');
      var savedDate   = localStorage.getItem(LSK + '_date');
      var defaultDate = (savedCity === city && savedDate && availableDates.includes(savedDate))
        ? savedDate : null;

      var calPanel = document.getElementById('ce-cal-panel-' + WID);

      fpInstance = flatpickr('#ce-date-' + WID, {
        locale:      'es',
        dateFormat:  'Y-m-d',
        minDate:     availableDates[0],
        enable:      availableDates,
        inline:      true,
        appendTo:    calPanel,
        defaultDate: defaultDate,
        onChange:    function(dates, dateStr) { onDateSelected(city, dateStr); },
      });

      if (defaultDate) {
        updateDateDisplay(defaultDate);
        closeCalPanel();
        onDateSelected(city, defaultDate);
      } else {
        openCalPanel();
        showMsg('✅ ' + availableDates.length + ' fecha(s) disponible(s) — elige una', 'success');
      }
    });
  }

  function loadFlatpickrLib(callback) {
    if (window.__ceFpReady) { callback(); return; }
    if (window.__ceFpLoading) {
      var t = setInterval(function() { if (window.__ceFpReady) { clearInterval(t); callback(); } }, 50);
      return;
    }
    window.__ceFpLoading = true;

    if (!document.querySelector('link[href*="flatpickr"]')) {
      var css  = document.createElement('link');
      css.rel  = 'stylesheet';
      css.href = 'https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css';
      document.head.appendChild(css);
    }

    if (typeof flatpickr !== 'undefined') { window.__ceFpReady = true; callback(); return; }

    var s1 = document.createElement('script');
    s1.src    = 'https://cdn.jsdelivr.net/npm/flatpickr';
    s1.onload = function() {
      var s2 = document.createElement('script');
      s2.src    = 'https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js';
      s2.onload = function() { window.__ceFpReady = true; callback(); };
      document.head.appendChild(s2);
    };
    document.head.appendChild(s1);
  }

  // ── Date selected ─────────────────────────────────────────────
  function onDateSelected(city, dateStr) {
    localStorage.setItem(LSK + '_city', city);
    localStorage.setItem(LSK + '_date', dateStr);
    updateCartAttributes({ delivery_city: city, delivery_date: dateStr, delivery_type: 'delivery' });
    deliverySelected = true;
    updateDateDisplay(dateStr);
    closeCalPanel();
    showMsg('✅ Entrega: ' + city + ' · ' + dateStr, 'success');
    notifyState();
    console.log('[Calendify-Debug] fecha seleccionada – city:', city, '| date:', dateStr);
  }

  // ── Cart attributes ───────────────────────────────────────────
  async function updateCartAttributes(attrs) {
    try {
      var fd = new FormData();
      Object.entries(attrs).forEach(function(pair) {
        fd.append('attributes[' + pair[0] + ']', pair[1]);
      });
      await fetch('/cart/update.js', { method: 'POST', body: fd });
    } catch (_) {}
  }

  // ── Restore selection ─────────────────────────────────────────
  function restoreFromLocalStorage() {
    var savedCity = localStorage.getItem(LSK + '_city');
    if (!savedCity) { restoreFromCartAttributes(); return; }

    var select  = $w('city');
    var options = Array.from(select.options);
    var match   = options.find(function(o) { return o.value === savedCity; });
    if (match) { select.value = savedCity; onCityChange(); }
  }

  async function restoreFromCartAttributes() {
    try {
      var res   = await fetch('/cart.js');
      var cart  = await res.json();
      var attrs = cart.attributes || {};
      if (attrs.delivery_city) {
        localStorage.setItem(LSK + '_city', attrs.delivery_city);
        if (attrs.delivery_date) localStorage.setItem(LSK + '_date', attrs.delivery_date);
        restoreFromLocalStorage();
      }
    } catch (_) {}
  }

  // ── Checkout interception ─────────────────────────────────────
  function setupCheckoutInterception() {
    if (window.__ceInterceptor) return;
    window.__ceInterceptor = true;

    document.addEventListener('submit', onFormSubmit,     true);
    document.addEventListener('click',  onLinkClick,      true);
    // Capture-phase en document: dispara ANTES que cualquier handler en el
    // elemento (incluido el connectedCallback de shopify-buy-it-now-button)
    document.addEventListener('click',  onCustomBtnClick, true);

    var mo = new MutationObserver(markInterceptedButtons);
    mo.observe(document.body, { childList: true, subtree: true });
  }

  function requiresSelection() {
    var cfg = window.__ceCfg;
    return !cfg || cfg.requireDelivery !== false;
  }

  function canCheckout() {
    if (!requiresSelection()) return true;
    return deliverySelected || pickupSelected;
  }

  function alertAndScroll() {
    var widget = document.getElementById('ce-widget-' + WID);
    if (widget) widget.scrollIntoView({ behavior: 'smooth', block: 'center' });
    setTimeout(function() {
      alert('⚠️ Por favor selecciona una ciudad y fecha de entrega antes de continuar al checkout.');
    }, 300);
  }

  function onFormSubmit(e) {
    var form      = e.target;
    var action    = (form.action || '').toLowerCase();
    var submitter = e.submitter;

    // form.querySelector solo encuentra hijos DOM del form.
    // Botones con form="cart" fuera del form DOM no son hijos → usar e.submitter.
    var hasBtn = form.querySelector('[name="checkout"]') ||
                 (submitter && submitter.name === 'checkout');

    console.log('[Calendify-Debug] submit event – action:', action,
                '| submitter:', submitter && ('#' + submitter.id), submitter && submitter.name,
                '| hasBtn:', !!hasBtn);

    if (!action.includes('/checkout') && !hasBtn) return;

    if (!canCheckout()) {
      e.preventDefault();
      e.stopPropagation();
      console.log('[Calendify-Debug] submit BLOQUEADO – sin selección');
      alertAndScroll();
      return;
    }

    // Si el submit viene de un botón name="checkout" (que asocia el form via form="cart"),
    // el form action es /cart — no funciona inyectar un hidden field.
    // Hay que prevenir el submit nativo y redirigir manualmente a /checkout.
    if (submitter && submitter.name === 'checkout') {
      e.preventDefault();
      e.stopPropagation();
      var city2 = !pickupSelected ? (localStorage.getItem(LSK + '_city') || '') : '';
      var date2 = !pickupSelected ? (localStorage.getItem(LSK + '_date') || '') : '';
      console.log('[Calendify-Debug] submit checkout redirect – city:', city2, '| date:', date2);
      var fd2 = new FormData();
      fd2.append('attributes[delivery_type]', pickupSelected ? 'pickup' : 'delivery');
      fd2.append('attributes[delivery_city]', city2);
      fd2.append('attributes[delivery_date]', date2);
      fetch('/cart/update.js', { method: 'POST', body: fd2 }).finally(function() {
        var url2 = pickupSelected
          ? '/checkout'
          : '/checkout?checkout[shipping_address][city]=' + encodeURIComponent(city2);
        console.log('[Calendify-Debug] submit redirect →', url2);
        window.location.href = url2;
      });
      return;
    }

    // Para forms cuyo action ya apunta a /checkout, inyectar ciudad como campo oculto
    injectCityIntoForm(form);
  }

  function onLinkClick(e) {
    var link = e.target.closest('a[href*="/checkout"]');
    if (!link) return;

    if (!canCheckout()) {
      e.preventDefault();
      e.stopPropagation();
      alertAndScroll();
      return;
    }

    var city = localStorage.getItem(LSK + '_city');
    if (city && !pickupSelected) {
      try {
        var url = new URL(link.href);
        url.searchParams.set('checkout[shipping_address][city]', city);
        link.href = url.toString();
      } catch (_) {}
    }
  }

  function injectCityIntoForm(form) {
    var city = localStorage.getItem(LSK + '_city');
    if (!city || pickupSelected) return;

    var field = 'checkout[shipping_address][city]';
    if (!form.querySelector('[name="' + field + '"]')) {
      var inp   = document.createElement('input');
      inp.type  = 'hidden';
      inp.name  = field;
      inp.value = city;
      form.appendChild(inp);
    }
  }

  // ── Interceptación combinada: Capa 1 (auto) + Capa 2 (manual) ──
  function getInterceptedSelectors() {
    var selectors = CE_AUTO_SELECTORS.slice();
    var cfg       = window.__ceCfg || {};

    // Legacy: checkoutButtonClasses (nombres de clase, comma-separated o JSON)
    var legacyRaw = cfg.checkoutButtonClasses || '';
    if (legacyRaw) {
      try {
        var parsed = JSON.parse(legacyRaw);
        if (Array.isArray(parsed)) {
          parsed.forEach(function(cls) { if (cls) selectors.push('.' + CSS.escape(cls)); });
        }
      } catch (_) {
        legacyRaw.split(',').forEach(function(cls) {
          cls = cls.trim();
          if (cls) selectors.push('.' + CSS.escape(cls));
        });
      }
    }

    // Nuevo: selectedButtonSelectors (selectores CSS guardados desde modo selección visual)
    try {
      var selected = JSON.parse(cfg.selectedButtonSelectors || '[]');
      if (Array.isArray(selected)) {
        selected.forEach(function(sel) { if (sel) selectors.push(sel); });
      }
    } catch (_) {}

    return selectors;
  }

  function onCustomBtnClick(e) {
    // No interceptar durante el modo de selección visual
    if (window.__ceSelectionMode) return;

    var selectors = getInterceptedSelectors();

    var btn = null;
    for (var i = 0; i < selectors.length; i++) {
      try {
        var found = e.target.closest(selectors[i]);
        if (found) { btn = found; break; }
      } catch (_) {}
    }
    if (!btn) return;

    // Confirmar que es un botón de checkout: prevenir default y detener propagación
    e.preventDefault();
    e.stopPropagation();
    e.stopImmediatePropagation();

    console.log('[Calendify-Debug] click capturado (document-capture) btn:', btn.tagName,
                '#' + btn.id, 'name=' + btn.name, btn.className);
    console.log('[Calendify-Debug] localStorage city:', localStorage.getItem(LSK + '_city'),
                '| date:', localStorage.getItem(LSK + '_date'));
    console.log('[Calendify-Debug] deliverySelected:', deliverySelected,
                '| pickupSelected:', pickupSelected,
                '| canCheckout():', canCheckout());

    if (!canCheckout()) {
      console.log('[Calendify-Debug] checkout BLOQUEADO – sin ciudad/fecha seleccionada');
      alertAndScroll();
      return;
    }

    var city = !pickupSelected ? (localStorage.getItem(LSK + '_city') || '') : '';
    var date = !pickupSelected ? (localStorage.getItem(LSK + '_date') || '') : '';

    console.log('[Calendify-Debug] flush cart attrs – city:', city, '| date:', date);

    var fd = new FormData();
    fd.append('attributes[delivery_type]', pickupSelected ? 'pickup' : 'delivery');
    fd.append('attributes[delivery_city]', city);
    fd.append('attributes[delivery_date]', date);

    fetch('/cart/update.js', { method: 'POST', body: fd })
      .then(function(res) {
        console.log('[Calendify-Debug] cart attrs guardados – HTTP', res.status);
      })
      .catch(function(err) {
        console.warn('[Calendify-Debug] error guardando cart attrs:', err);
      })
      .finally(function() {
        // Redirigir a checkout con ciudad en la URL del shipping address
        // (misma estrategia que el legacy api.script.js)
        var checkoutUrl = pickupSelected
          ? '/checkout'
          : '/checkout?checkout[shipping_address][city]=' + encodeURIComponent(city);
        console.log('[Calendify-Debug] redirigiendo a:', checkoutUrl);
        window.location.href = checkoutUrl;
      });
  }

  function markInterceptedButtons() {
    var selectors = getInterceptedSelectors();
    selectors.forEach(function(sel) {
      try {
        document.querySelectorAll(sel).forEach(function(btn) {
          if (btn.dataset.ceIntercepted) return;
          btn.dataset.ceIntercepted = '1';
          console.log('[Calendify-Debug] botón marcado para interceptación:', sel);
        });
      } catch (_) {}
    });
  }

  // ── Global state ───────────────────────────────────────────────
  function notifyState() {
    window.__ceReady = deliverySelected || pickupSelected;
  }

})();
</script>

{% schema %}
{
  "name": "Calendario de Entregas",
  "target": "section",
  "settings": [
    {
      "type": "checkbox",

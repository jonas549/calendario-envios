{% comment %}
  App Embed — target: body — se inyecta en TODAS las páginas del tema.
  Aparece como toggle en Theme Editor → App embeds → "Calendify Delivery".
  Solo contiene el modo selección visual (?ce_select_mode=1).
  El widget de entrega (calendario, ciudad, pickup) vive en calendar-widget.liquid.
{% endcomment %}
<script>
(function() {
  'use strict';

  var u = new URL(window.location.href);
  if (u.searchParams.get('ce_select_mode') !== '1') return;

  // Marcar globalmente para que el App Block no intercepte clicks durante este modo
  window.__ceSelectionMode = true;

  var SHOP = {{ shop.permanent_domain | json }};

  var CE_SELECTORS = [
    '[name="checkout"]',
    'button[name="checkout"]',
    'input[name="checkout"]',
    'shopify-buy-it-now-button',
    'shopify-payment-button',
    '.shopify-payment-button__button',
    '.cart__checkout-button',
    '.cart-checkout-button',
    '#CartSubmit',
    '.cart__submit',
    '.cart__checkout',
    '.cart-form__checkout',
    '[data-checkout-url]',
    '[data-action="checkout"]',
    '.product-form__buy-it-now',
    '.dynamic-checkout__content button',
    'a[href="/checkout"]',
  ];

  var selected = [];

  // ── Estilos ────────────────────────────────────────────────────
  var style = document.createElement('style');
  style.textContent = [
    '@keyframes ce-pulse{',
      '0%,100%{box-shadow:0 0 0 3px rgba(255,153,0,.9),0 0 0 6px rgba(255,153,0,.2)}',
      '50%{box-shadow:0 0 0 4px rgba(255,100,0,.9),0 0 0 10px rgba(255,100,0,.08)}',
    '}',
    '#ce-sel-bar{',
      'position:fixed;top:0;left:0;right:0;z-index:2147483647;',
      'background:linear-gradient(135deg,#e65c00 0%,#ff9900 100%);',
      'color:#fff;padding:0 16px;min-height:56px;',
      'display:flex;align-items:center;gap:12px;flex-wrap:wrap;',
      'font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,sans-serif;',
      'font-size:13px;box-shadow:0 4px 16px rgba(230,92,0,.5);}',
    '#ce-sel-bar .ce-title{font-size:15px;font-weight:800;white-space:nowrap;letter-spacing:-.2px;}',
    '#ce-sel-bar .ce-hint{flex:1;font-size:12px;opacity:.9;min-width:160px;}',
    '#ce-sel-count{background:rgba(0,0,0,.2);border-radius:20px;padding:4px 14px;',
      'font-weight:700;white-space:nowrap;font-size:13px;}',
    '.ce-act{border:none;border-radius:6px;padding:9px 20px;',
      'cursor:pointer;font-size:13px;font-weight:700;transition:opacity .15s;}',
    '#ce-btn-save{background:#fff;color:#c85000;}',
    '#ce-btn-save:hover:not(:disabled){background:#f5f5f5;}',
    '#ce-btn-save:disabled{opacity:.45;cursor:not-allowed;}',
    '#ce-btn-cancel{background:transparent;color:#fff;',
      'border:1.5px solid rgba(255,255,255,.65) !important;}',
    '#ce-btn-cancel:hover{background:rgba(255,255,255,.15);}',
    '#ce-no-btns{',
      'position:fixed;top:64px;left:50%;transform:translateX(-50%);z-index:2147483646;',
      'background:#1a1a2e;color:#fff;border-radius:10px;padding:14px 22px;',
      'font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;',
      'font-size:13px;max-width:92vw;text-align:center;',
      'box-shadow:0 6px 24px rgba(0,0,0,.45);line-height:1.5;}',
    '#ce-toast{',
      'position:fixed;bottom:28px;left:50%;transform:translateX(-50%);z-index:2147483647;',
      'background:#1a7f4b;color:#fff;border-radius:10px;padding:14px 28px;',
      'font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;',
      'font-size:15px;font-weight:700;box-shadow:0 6px 24px rgba(0,0,0,.35);',
      'opacity:0;transition:opacity .3s ease;pointer-events:none;}',
    '.ce-sel-hl{',
      'outline:none !important;',
      'box-shadow:0 0 0 3px rgba(255,153,0,.9),0 0 0 6px rgba(255,153,0,.2) !important;',
      'cursor:crosshair !important;',
      'animation:ce-pulse 1.4s ease-in-out infinite !important;',
      'position:relative !important;}',
    '.ce-sel-hl.ce-sel-on{',
      'box-shadow:0 0 0 3px #00cc66 !important;',
      'animation:none !important;',
      'background:rgba(0,204,102,.10) !important;}',
    '.ce-chk{',
      'position:absolute !important;top:-9px !important;right:-9px !important;',
      'background:#00cc66;color:#fff;border-radius:50%;',
      'width:22px !important;height:22px !important;',
      'display:flex !important;align-items:center !important;justify-content:center !important;',
      'font-size:13px !important;font-weight:900 !important;',
      'pointer-events:none !important;z-index:2147483645 !important;',
      'box-shadow:0 1px 4px rgba(0,0,0,.3) !important;}',
  ].join('');
  document.head.appendChild(style);

  // ── Barra superior ─────────────────────────────────────────────
  function buildBar() {
    var bar = document.createElement('div');
    bar.id  = 'ce-sel-bar';
    bar.innerHTML =
      '<span class="ce-title">&#127919;&nbsp;MODO SELECCI&Oacute;N &mdash; Calendify</span>' +
      '<span class="ce-hint">Haz clic en los botones de checkout que deben requerir fecha de entrega</span>' +
      '<span id="ce-sel-count">0 seleccionados</span>' +
      '<button id="ce-btn-save" class="ce-act" disabled>Guardar selecci&oacute;n</button>' +
      '<button id="ce-btn-cancel" class="ce-act">Cancelar</button>';

    if (document.body.firstChild) {
      document.body.insertBefore(bar, document.body.firstChild);
    } else {
      document.body.appendChild(bar);
    }

    document.body.style.paddingTop =
      (parseInt(document.body.style.paddingTop || '0', 10) + 56) + 'px';

    document.getElementById('ce-btn-save').addEventListener('click', doSave);
    document.getElementById('ce-btn-cancel').addEventListener('click', doCancel);
  }

  function updateCount() {
    var n  = selected.length;
    var el = document.getElementById('ce-sel-count');
    if (el) el.textContent = n + (n === 1 ? ' seleccionado' : ' seleccionados');
    var btn = document.getElementById('ce-btn-save');
    if (btn) btn.disabled = (n === 0);
  }

  // ── Construir selector CSS único para un elemento ──────────────
  function buildSelector(el) {
    if (el.id && !/^\d/.test(el.id)) return '#' + CSS.escape(el.id);
    var tag = el.tagName.toLowerCase();
    var cls = Array.from(el.classList)
      .filter(function(c) { return c !== 'ce-sel-hl' && c !== 'ce-sel-on'; })
      .slice(0, 3)
      .map(function(c) { return '.' + CSS.escape(c); })
      .join('');
    if (cls) return tag + cls;
    var nm = el.getAttribute('name');
    if (nm) return tag + '[name="' + nm + '"]';
    return tag;
  }

  // ── Resaltar un botón detectado ────────────────────────────────
  function highlightBtn(el) {
    if (el._ceHl) return;
    el._ceHl = true;
    el.classList.add('ce-sel-hl');
    if (getComputedStyle(el).position === 'static') el.style.position = 'relative';

    el.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();

      var sel = buildSelector(el);
      var idx = selected.indexOf(sel);

      if (idx === -1) {
        selected.push(sel);
        el.classList.add('ce-sel-on');
        if (!el.querySelector('.ce-chk')) {
          var badge = document.createElement('span');
          badge.className   = 'ce-chk';
          badge.textContent = '✓';
          el.appendChild(badge);
        }
      } else {
        selected.splice(idx, 1);
        el.classList.remove('ce-sel-on');
        var b = el.querySelector('.ce-chk');
        if (b) b.remove();
      }
      updateCount();
    }, true);
  }

  // ── Escanear y resaltar botones ────────────────────────────────
  function scan() {
    var found = 0;
    CE_SELECTORS.forEach(function(sel) {
      try {
        document.querySelectorAll(sel).forEach(function(el) {
          if (el.closest('#ce-sel-bar')) return;
          if (el.offsetParent === null && el.tagName !== 'INPUT') return;
          highlightBtn(el);
          found++;
        });
      } catch (_) {}
    });
    return found;
  }

  // ── Mensaje si no hay botones en la página actual ──────────────
  function showNoBtnsMsg(found) {
    var existing = document.getElementById('ce-no-btns');
    if (found > 0) { if (existing) existing.remove(); return; }
    if (existing) return;
    var div       = document.createElement('div');
    div.id        = 'ce-no-btns';
    div.innerHTML =
      '&#9888;&#65039; <strong>No se detectaron botones de checkout en esta p&aacute;gina.</strong><br>' +
      'Navega al carrito (<code>/cart</code>) o a una p&aacute;gina de producto para ver los botones resaltados.';
    document.body.appendChild(div);
  }

  // ── Guardar ────────────────────────────────────────────────────
  function doSave() {
    var btn         = document.getElementById('ce-btn-save');
    btn.disabled    = true;
    btn.textContent = 'Guardando...';

    fetch('/apps/proxy/api/button-selectors', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ shop: SHOP, selectors: selected }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        var n = selected.length;
        showToast('✅ ¡Guardado! ' + n + (n === 1 ? ' botón configurado' : ' botones configurados'));
        setTimeout(function() {
          window.close();
          setTimeout(function() {
            var cu = new URL(window.location.href);
            cu.searchParams.delete('ce_select_mode');
            window.location.href = cu.toString();
          }, 400);
        }, 1800);
      } else {
        btn.textContent = '❌ Error — reintentar';
        btn.disabled    = false;
      }
    })
    .catch(function() {
      btn.textContent = '❌ Error — reintentar';
      var b = document.getElementById('ce-btn-save');
      if (b) b.disabled = false;
    });
  }

  function doCancel() {
    var cu = new URL(window.location.href);
    cu.searchParams.delete('ce_select_mode');
    window.location.href = cu.toString();
  }

  // ── Toast ──────────────────────────────────────────────────────
  function showToast(msg) {
    var t = document.getElementById('ce-toast');
    if (!t) { t = document.createElement('div'); t.id = 'ce-toast'; document.body.appendChild(t); }
    t.textContent   = msg;
    t.style.opacity = '1';
    setTimeout(function() { t.style.opacity = '0'; }, 3500);
  }

  // ── Init ───────────────────────────────────────────────────────
  function init() {
    buildBar();
    var found = scan();
    showNoBtnsMsg(found);
    new MutationObserver(function() {
      var f = scan();
      showNoBtnsMsg(f);
    }).observe(document.body, { childList: true, subtree: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

})();
</script>

{% schema %}
{
  "name": "Calendify Delivery",
  "target": "body",
  "settings": []
}
{% endschema %}

{% comment %}
  App Embed — target: body — inyectado en TODAS las páginas del tema.

  Parte 1: Interceptación universal de checkout (siempre activa en todas las páginas).
  Parte 2: Modo selección visual (activo solo con ?ce_select_mode=1 o sessionStorage).
{% endcomment %}
<script>
(function() {
  'use strict';

  console.log('[Calendify Embed] Script cargado en:', window.location.pathname);

  var SHOP = {{ shop.permanent_domain | json }};
  var LSK  = 'ce_' + SHOP.replace(/\./g, '_');

  window.__ceShop = SHOP;

  // ═══════════════════════════════════════════════════════════════
  // PARTE 1 — INTERCEPTACIÓN UNIVERSAL DE CHECKOUT
  // Se ejecuta en TODAS las páginas, siempre.
  // ═══════════════════════════════════════════════════════════════

  var AUTO_SELECTORS = [
    '[name="checkout"]',
    'button[name="checkout"]',
    'input[name="checkout"]',
    'shopify-buy-it-now-button',
    'shopify-payment-button',
    '.shopify-payment-button__button',
    '.cart__checkout-button',
    '.cart-checkout-button',
    '#CartSubmit',
    '.cart__submit',
    '.cart__checkout',
    '.cart-form__checkout',
    '[data-checkout-url]',
    '[data-action="checkout"]',
    '.product-form__buy-it-now',
    '.dynamic-checkout__content button',
    'a[href="/checkout"]',
  ];

  var savedSelectors = [];  // cargados asincrónicamente desde la API

  function getAllSelectors() {
    return AUTO_SELECTORS.concat(savedSelectors);
  }

  // Carga selectores guardados por el merchant (modo selección visual) desde la API
  function loadSavedSelectors() {
    fetch('/apps/proxy/api/button-selectors?shop=' + encodeURIComponent(SHOP))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success && Array.isArray(data.selectors) && data.selectors.length) {
          data.selectors.forEach(function(sel) {
            if (sel && AUTO_SELECTORS.indexOf(sel) === -1 && savedSelectors.indexOf(sel) === -1) {
              savedSelectors.push(sel);
            }
          });
          console.log('[Calendify Embed] Selectores guardados cargados:', savedSelectors.length, savedSelectors);
          markInterceptedButtons();
        }
      })
      .catch(function() {});
  }

  // ── Estado del delivery ────────────────────────────────────────
  // Prioridad: window.__ceState (escrito por App Block si está en esta página) → localStorage

  function requiresSelection() {
    var cfg = window.__ceCfg;
    return !cfg || cfg.requireDelivery !== false;
  }

  function isPickup() {
    if (window.__ceState) return !!window.__ceState.pickup;
    return localStorage.getItem(LSK + '_pickup') === 'true';
  }

  function getCity() {
    if (window.__ceState && !window.__ceState.pickup) return window.__ceState.city || '';
    if (isPickup()) return '';
    return localStorage.getItem(LSK + '_city') || '';
  }

  function getDate() {
    if (window.__ceState && !window.__ceState.pickup) return window.__ceState.date || '';
    return localStorage.getItem(LSK + '_date') || '';
  }

  function canCheckout() {
    if (!requiresSelection()) return true;
    if (isPickup()) return true;
    return !!(getCity() && getDate());
  }

  function alertAndScroll() {
    var widget = document.querySelector('[id^="ce-widget-"]');
    if (widget) widget.scrollIntoView({ behavior: 'smooth', block: 'center' });
    setTimeout(function() {
      alert('⚠️ Por favor selecciona una ciudad y fecha de entrega antes de continuar al checkout.');
    }, 300);
  }

  function doCheckoutRedirect() {
    var pickup = isPickup();
    var city   = !pickup ? getCity() : '';
    var date   = !pickup ? getDate() : '';

    console.log('[Calendify Embed] checkout redirect – city:', city, '| date:', date, '| pickup:', pickup);

    var fd = new FormData();
    fd.append('attributes[delivery_type]', pickup ? 'pickup' : 'delivery');
    fd.append('attributes[delivery_city]', city);
    fd.append('attributes[delivery_date]', date);

    fetch('/cart/update.js', { method: 'POST', body: fd })
      .finally(function() {
        var checkoutUrl = pickup
          ? '/checkout'
          : '/checkout?checkout[shipping_address][city]=' + encodeURIComponent(city);
        console.log('[Calendify Embed] redirigiendo a:', checkoutUrl);
        window.location.href = checkoutUrl;
      });
  }

  // ── Listeners de interceptación ────────────────────────────────

  function onCustomBtnClick(e) {
    if (window.__ceSelectionMode) return;

    var selectors = getAllSelectors();
    var btn = null;
    for (var i = 0; i < selectors.length; i++) {
      try {
        var found = e.target.closest(selectors[i]);
        if (found) { btn = found; break; }
      } catch (_) {}
    }
    if (!btn) return;

    e.preventDefault();
    e.stopPropagation();
    e.stopImmediatePropagation();

    console.log('[Calendify Embed] Click capturado en:', btn.tagName, '#' + btn.id, 'name=' + btn.name);
    console.log('[Calendify Embed] canCheckout:', canCheckout(), '| city:', getCity(), '| date:', getDate());

    if (!canCheckout()) {
      console.log('[Calendify Embed] checkout BLOQUEADO – sin ciudad/fecha');
      alertAndScroll();
      return;
    }

    doCheckoutRedirect();
  }

  function onFormSubmit(e) {
    var form      = e.target;
    var action    = (form.action || '').toLowerCase();
    var submitter = e.submitter;

    // form.querySelector solo encuentra hijos DOM — botones con form="formId" fuera
    // del DOM del form no son hijos, por eso verificamos e.submitter también.
    var isCheckout = action.includes('/checkout') ||
                     form.querySelector('[name="checkout"]') ||
                     (submitter && submitter.name === 'checkout');

    console.log('[Calendify Embed] submit event – action:', action,
                '| submitter:', submitter ? ('#' + submitter.id + ' name=' + submitter.name) : 'none',
                '| isCheckout:', isCheckout);

    if (!isCheckout) return;

    if (!canCheckout()) {
      e.preventDefault();
      e.stopPropagation();
      console.log('[Calendify Embed] submit BLOQUEADO – sin ciudad/fecha');
      alertAndScroll();
      return;
    }

    // Botón name="checkout" asociado a form /cart → redirect manual (form POST va a /cart, no /checkout)
    if (submitter && submitter.name === 'checkout') {
      e.preventDefault();
      e.stopPropagation();
      doCheckoutRedirect();
      return;
    }

    // Form cuyo action ya apunta a /checkout → inyectar ciudad como campo oculto
    if (!isPickup()) {
      var city  = getCity();
      var field = 'checkout[shipping_address][city]';
      if (city && !form.querySelector('[name="' + field + '"]')) {
        var inp   = document.createElement('input');
        inp.type  = 'hidden';
        inp.name  = field;
        inp.value = city;
        form.appendChild(inp);
      }
    }
  }

  function onLinkClick(e) {
    var link = e.target.closest('a[href*="/checkout"]');
    if (!link) return;

    if (!canCheckout()) {
      e.preventDefault();
      e.stopPropagation();
      alertAndScroll();
      return;
    }

    var city = !isPickup() ? getCity() : '';
    if (city) {
      try {
        var url = new URL(link.href);
        url.searchParams.set('checkout[shipping_address][city]', city);
        link.href = url.toString();
      } catch (_) {}
    }
  }

  function markInterceptedButtons() {
    getAllSelectors().forEach(function(sel) {
      try {
        document.querySelectorAll(sel).forEach(function(btn) {
          if (btn.dataset.ceIntercepted) return;
          btn.dataset.ceIntercepted = '1';
          console.log('[Calendify Embed] Botón detectado:', sel,
                      btn.id ? '#' + btn.id : btn.tagName);
        });
      } catch (_) {}
    });
  }

  function setupInterception() {
    if (window.__ceInterceptor) return;
    window.__ceInterceptor = true;

    document.addEventListener('submit', onFormSubmit,     true);
    document.addEventListener('click',  onLinkClick,      true);
    document.addEventListener('click',  onCustomBtnClick, true);

    new MutationObserver(markInterceptedButtons)
      .observe(document.body, { childList: true, subtree: true });

    console.log('[Calendify Embed] Interceptación universal activa');
  }

  // Arrancar la interceptación lo antes posible
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      setupInterception();
      markInterceptedButtons();
      loadSavedSelectors();
    });
  } else {
    setupInterception();
    markInterceptedButtons();
    loadSavedSelectors();
  }

  // ═══════════════════════════════════════════════════════════════
  // PARTE 2 — MODO SELECCIÓN VISUAL
  // Solo se ejecuta si ?ce_select_mode=1 o sessionStorage lo indica.
  // ═══════════════════════════════════════════════════════════════

  var SS_MODE  = 'ce_sel_active';
  var SS_SELS  = 'ce_sel_sels';
  var SS_INTRO = 'ce_sel_intro';

  var urlMode = new URL(window.location.href).searchParams.get('ce_select_mode') === '1';
  var ssMode  = sessionStorage.getItem(SS_MODE) === '1';

  console.log('[Calendify Embed] urlMode:', urlMode, '| ssMode:', ssMode,
              '→ modo selección:', (urlMode || ssMode) ? 'ACTIVO' : 'INACTIVO');

  if (!urlMode && !ssMode) return;

  // Primera activación = llega desde el link del admin (URL param, sin sesión previa)
  var firstActivation = urlMode && !ssMode;

  sessionStorage.setItem(SS_MODE, '1');
  window.__ceSelectionMode = true;

  // Cargar selecciones de páginas anteriores en esta sesión
  var selected;
  try { selected = JSON.parse(sessionStorage.getItem(SS_SELS) || '[]'); }
  catch (_) { selected = []; }

  function persistSelected() {
    sessionStorage.setItem(SS_SELS, JSON.stringify(selected));
  }

  // ── Estilos ────────────────────────────────────────────────────
  var style = document.createElement('style');
  style.textContent = [
    '@keyframes ce-pulse{',
      '0%,100%{box-shadow:0 0 0 3px rgba(255,153,0,.9),0 0 0 7px rgba(255,153,0,.2)}',
      '50%{box-shadow:0 0 0 4px rgba(255,100,0,1),0 0 0 11px rgba(255,100,0,.07)}',
    '}',
    '#ce-sel-bar{',
      'position:fixed;top:0;left:0;right:0;z-index:2147483647;',
      'background:linear-gradient(135deg,#e65c00 0%,#ff9900 100%);',
      'color:#fff;padding:8px 14px;',
      'display:flex;align-items:center;gap:10px;flex-wrap:wrap;',
      'font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,sans-serif;',
      'font-size:13px;box-shadow:0 4px 16px rgba(230,92,0,.55);min-height:52px;}',
    '#ce-sel-bar .ce-ttl{font-size:14px;font-weight:800;white-space:nowrap;}',
    '#ce-sel-bar .ce-hint{flex:1;font-size:11px;opacity:.88;min-width:140px;}',
    '#ce-sel-count{background:rgba(0,0,0,.22);border-radius:20px;padding:3px 12px;',
      'font-weight:700;white-space:nowrap;font-size:12px;}',
    '.ce-b{border:none;border-radius:5px;padding:7px 14px;',
      'cursor:pointer;font-size:12px;font-weight:700;white-space:nowrap;}',
    '#ce-b-save{background:#00cc66;color:#000;}',
    '#ce-b-save:hover:not(:disabled){background:#00aa55;}',
    '#ce-b-save:disabled{opacity:.4;cursor:not-allowed;}',
    '#ce-b-done{background:#0066cc;color:#fff;}',
    '#ce-b-done:hover:not(:disabled){background:#0052a3;}',
    '#ce-b-done:disabled{opacity:.4;cursor:not-allowed;}',
    '#ce-b-cancel{background:transparent;color:#fff;',
      'border:1.5px solid rgba(255,255,255,.6) !important;}',
    '#ce-b-cancel:hover{background:rgba(255,255,255,.12);}',
    '#ce-intro{',
      'position:fixed;top:60px;left:50%;transform:translateX(-50%);z-index:2147483646;',
      'background:#1a1a2e;color:#fff;border-radius:12px;padding:18px 22px 14px;',
      'font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;',
      'font-size:13px;max-width:min(440px,92vw);line-height:1.6;',
      'box-shadow:0 8px 32px rgba(0,0,0,.5);}',
    '#ce-intro h4{margin:0 0 10px;font-size:15px;font-weight:800;}',
    '#ce-intro ul{margin:0 0 14px;padding-left:18px;}',
    '#ce-intro li{margin-bottom:4px;}',
    '#ce-intro-ok{display:block;width:100%;border:none;border-radius:6px;padding:10px;',
      'background:#ff9900;color:#000;font-size:13px;font-weight:700;cursor:pointer;}',
    '#ce-intro-ok:hover{background:#e68a00;}',
    '#ce-no-btns{',
      'position:fixed;top:60px;left:50%;transform:translateX(-50%);z-index:2147483645;',
      'background:#2d2d2d;color:#eee;border-radius:10px;padding:12px 20px;',
      'font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;',
      'font-size:13px;max-width:92vw;text-align:center;',
      'box-shadow:0 6px 24px rgba(0,0,0,.4);line-height:1.5;}',
    '#ce-toast{',
      'position:fixed;bottom:28px;left:50%;transform:translateX(-50%);z-index:2147483647;',
      'background:#1a7f4b;color:#fff;border-radius:10px;padding:13px 26px;',
      'font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;',
      'font-size:15px;font-weight:700;box-shadow:0 6px 24px rgba(0,0,0,.3);',
      'opacity:0;transition:opacity .3s ease;pointer-events:none;}',
    '.ce-sel-hl{',
      'outline:none !important;',
      'box-shadow:0 0 0 3px rgba(255,153,0,.9),0 0 0 7px rgba(255,153,0,.18) !important;',
      'cursor:crosshair !important;',
      'animation:ce-pulse 1.5s ease-in-out infinite !important;',
      'position:relative !important;}',
    '.ce-sel-hl.ce-sel-on{',
      'box-shadow:0 0 0 3px #00cc66 !important;',
      'animation:none !important;',
      'background:rgba(0,204,102,.10) !important;}',
    '.ce-chk{',
      'position:absolute !important;top:-9px !important;right:-9px !important;',
      'background:#00cc66;color:#fff;border-radius:50%;',
      'width:22px !important;height:22px !important;',
      'display:flex !important;align-items:center !important;justify-content:center !important;',
      'font-size:13px !important;font-weight:900 !important;',
      'pointer-events:none !important;z-index:2147483644 !important;',
      'box-shadow:0 1px 4px rgba(0,0,0,.3) !important;}',
  ].join('');
  document.head.appendChild(style);

  // ── Barra superior ─────────────────────────────────────────────
  function buildBar() {
    var bar = document.createElement('div');
    bar.id  = 'ce-sel-bar';
    bar.innerHTML =
      '<span class="ce-ttl">&#127919; MODO SELECCI&Oacute;N &mdash; Calendify</span>' +
      '<span class="ce-hint">Navega por tu tienda y haz clic en los botones de checkout que quieres activar</span>' +
      '<span id="ce-sel-count">' + countLabel() + '</span>' +
      '<button id="ce-b-save"  class="ce-b" ' + (selected.length ? '' : 'disabled') + '>&#128190; Guardar y seguir</button>' +
      '<button id="ce-b-done"  class="ce-b" ' + (selected.length ? '' : 'disabled') + '>&#10003; Listo, termin&eacute;</button>' +
      '<button id="ce-b-cancel" class="ce-b">&#10005; Cancelar</button>';

    if (document.body.firstChild) document.body.insertBefore(bar, document.body.firstChild);
    else document.body.appendChild(bar);

    document.body.style.paddingTop =
      (parseInt(document.body.style.paddingTop || '0', 10) + 56) + 'px';

    document.getElementById('ce-b-save').addEventListener('click', doSaveAndStay);
    document.getElementById('ce-b-done').addEventListener('click', doSaveAndClose);
    document.getElementById('ce-b-cancel').addEventListener('click', doCancel);
  }

  function countLabel() {
    var n = selected.length;
    return n + (n === 1 ? ' seleccionado' : ' seleccionados');
  }

  function updateCount() {
    var el = document.getElementById('ce-sel-count');
    if (el) el.textContent = countLabel();
    var empty = selected.length === 0;
    var s = document.getElementById('ce-b-save');
    var d = document.getElementById('ce-b-done');
    if (s) s.disabled = empty;
    if (d) d.disabled = empty;
  }

  // ── Tooltip de bienvenida (solo primera vez en la sesión) ──────
  function maybeShowIntro() {
    if (sessionStorage.getItem(SS_INTRO)) return;
    sessionStorage.setItem(SS_INTRO, '1');

    var box = document.createElement('div');
    box.id  = 'ce-intro';
    box.innerHTML =
      '<h4>&#127919; C&oacute;mo usar el modo selecci&oacute;n</h4>' +
      '<ul>' +
        '<li>Los botones de checkout detectados tienen <strong>borde naranja pulsante</strong></li>' +
        '<li>Haz clic en un bot&oacute;n para seleccionarlo &mdash; se vuelve <strong>verde &#10003;</strong></li>' +
        '<li>Puedes <strong>navegar a otras p&aacute;ginas</strong> &mdash; tus selecciones se conservan</li>' +
        '<li><em>&#128190; Guardar y seguir</em> = guarda pero contin&uacute;a seleccionando</li>' +
        '<li><em>&#10003; Listo, termin&eacute;</em> = guarda y cierra esta pesta&ntilde;a</li>' +
      '</ul>' +
      '<button id="ce-intro-ok">Entendido, empezar &#8594;</button>';
    document.body.appendChild(box);

    document.getElementById('ce-intro-ok').addEventListener('click', function() {
      box.style.opacity    = '0';
      box.style.transition = 'opacity .25s';
      setTimeout(function() { if (box.parentNode) box.remove(); }, 260);
    });
  }

  // ── Selector CSS único para un elemento ───────────────────────
  function buildSelector(el) {
    if (el.id && !/^\d/.test(el.id)) return '#' + CSS.escape(el.id);
    var tag = el.tagName.toLowerCase();
    var cls = Array.from(el.classList)
      .filter(function(c) { return c !== 'ce-sel-hl' && c !== 'ce-sel-on'; })
      .slice(0, 3)
      .map(function(c) { return '.' + CSS.escape(c); })
      .join('');
    if (cls) return tag + cls;
    var nm = el.getAttribute('name');
    if (nm) return tag + '[name="' + nm + '"]';
    return tag;
  }

  // Comprueba si un elemento coincide con algún selector de `selected`
  function isInSelected(el) {
    var elSel = buildSelector(el);
    if (selected.indexOf(elSel) !== -1) return true;
    for (var k = 0; k < selected.length; k++) {
      try { if (el.matches(selected[k])) return true; } catch (_) {}
    }
    return false;
  }

  // ── Resaltar un botón ──────────────────────────────────────────
  function highlightBtn(el) {
    if (el._ceHl) return;
    el._ceHl = true;
    el.classList.add('ce-sel-hl');
    if (getComputedStyle(el).position === 'static') el.style.position = 'relative';

    // Marcar si ya está en la lista actual (sessionStorage o backend cargado)
    if (isInSelected(el)) markSelected(el, false);

    el.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();

      var sel = buildSelector(el);
      var idx = selected.indexOf(sel);
      if (idx === -1) {
        selected.push(sel);
        markSelected(el, true);
      } else {
        selected.splice(idx, 1);
        unmarkSelected(el);
      }
      persistSelected();
      updateCount();
    }, true);
  }

  // Actualiza botones ya resaltados que aún no están en verde
  function refreshHighlights() {
    document.querySelectorAll('.ce-sel-hl:not(.ce-sel-on)').forEach(function(el) {
      if (isInSelected(el)) markSelected(el, false);
    });
  }

  function markSelected(el, animate) {
    el.classList.add('ce-sel-on');
    if (!el.querySelector('.ce-chk')) {
      var badge = document.createElement('span');
      badge.className   = 'ce-chk';
      badge.textContent = '✓';
      if (animate) {
        badge.style.transform  = 'scale(0)';
        badge.style.transition = 'transform .15s ease';
        el.appendChild(badge);
        requestAnimationFrame(function() { badge.style.transform = 'scale(1)'; });
      } else {
        el.appendChild(badge);
      }
    }
  }

  function unmarkSelected(el) {
    el.classList.remove('ce-sel-on');
    var b = el.querySelector('.ce-chk');
    if (b) {
      b.style.transition = 'transform .12s ease';
      b.style.transform  = 'scale(0)';
      setTimeout(function() { if (b.parentNode) b.remove(); }, 130);
    }
  }

  // ── Escanear y resaltar botones ────────────────────────────────
  function scan() {
    var found = 0;
    getAllSelectors().forEach(function(sel) {
      try {
        document.querySelectorAll(sel).forEach(function(el) {
          if (el.closest('#ce-sel-bar') || el.closest('#ce-intro')) return;
          if (el.offsetParent === null && el.tagName !== 'INPUT') return;
          highlightBtn(el);
          found++;
        });
      } catch (_) {}
    });
    return found;
  }

  function showNoBtnsMsg(found) {
    var existing = document.getElementById('ce-no-btns');
    if (found > 0) { if (existing) existing.remove(); return; }
    if (existing) return;
    var div = document.createElement('div');
    div.id  = 'ce-no-btns';
    div.innerHTML =
      '&#9888; <strong>No hay botones de checkout en esta p&aacute;gina.</strong><br>' +
      'Navega al carrito (<code>/cart</code>) o a una p&aacute;gina de producto.';
    document.body.appendChild(div);
  }

  // ── POST a la API ──────────────────────────────────────────────
  function saveToAPI(onSuccess) {
    var btn1 = document.getElementById('ce-b-save');
    var btn2 = document.getElementById('ce-b-done');
    if (btn1) { btn1.disabled = true; btn1.textContent = 'Guardando...'; }
    if (btn2)   btn2.disabled = true;

    fetch('/apps/proxy/api/button-selectors', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ shop: SHOP, selectors: selected }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        onSuccess();
      } else {
        restoreSaveBtns();
        showToast('❌ Error al guardar — intenta de nuevo');
      }
    })
    .catch(function() {
      restoreSaveBtns();
      showToast('❌ Error de red — intenta de nuevo');
    });
  }

  function restoreSaveBtns() {
    var btn1 = document.getElementById('ce-b-save');
    var btn2 = document.getElementById('ce-b-done');
    if (btn1) { btn1.disabled = selected.length === 0; btn1.innerHTML = '&#128190; Guardar y seguir'; }
    if (btn2) { btn2.disabled = selected.length === 0; }
  }

  // ── Limpiar modo (sessionStorage) ─────────────────────────────
  function clearMode() {
    sessionStorage.removeItem(SS_MODE);
    sessionStorage.removeItem(SS_SELS);
    sessionStorage.removeItem(SS_INTRO);
    window.__ceSelectionMode = false;
  }

  // ── Acciones ───────────────────────────────────────────────────

  // 💾 Guardar y seguir: guarda a API pero MANTIENE el modo activo
  function doSaveAndStay() {
    saveToAPI(function() {
      var n = selected.length;
      showToast('✅ ' + n + (n === 1 ? ' botón guardado' : ' botones guardados') + ' — puedes seguir seleccionando');
      restoreSaveBtns();
      // No clearMode(), no navigate — el merchant continúa donde está
    });
  }

  // ✓ Listo, terminé: guarda y cierra la pestaña
  function doSaveAndClose() {
    saveToAPI(function() {
      var n = selected.length;
      showToast('✅ ' + n + (n === 1 ? ' botón guardado' : ' botones guardados') + ' — cerrando...');
      clearMode();
      setTimeout(function() {
        window.close();
        // Fallback si window.close() no cierra
        setTimeout(function() {
          var cu = new URL(window.location.href);
          cu.searchParams.delete('ce_select_mode');
          window.location.href = cu.toString();
        }, 500);
      }, 1600);
    });
  }

  // ✗ Cancelar: sale sin guardar
  function doCancel() {
    clearMode();
    var cu = new URL(window.location.href);
    cu.searchParams.delete('ce_select_mode');
    window.location.href = cu.toString();
  }

  // ── Toast ──────────────────────────────────────────────────────
  function showToast(msg) {
    var t = document.getElementById('ce-toast');
    if (!t) { t = document.createElement('div'); t.id = 'ce-toast'; document.body.appendChild(t); }
    t.textContent   = msg;
    t.style.opacity = '1';
    setTimeout(function() { t.style.opacity = '0'; }, 4000);
  }

  // ── Cargar selectores del backend al iniciar por primera vez ──
  function loadFromBackend() {
    fetch('/apps/proxy/api/button-selectors?shop=' + encodeURIComponent(SHOP))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.success || !Array.isArray(data.selectors) || !data.selectors.length) return;
        var changed = false;
        data.selectors.forEach(function(sel) {
          if (selected.indexOf(sel) === -1) { selected.push(sel); changed = true; }
        });
        if (changed) {
          persistSelected();
          refreshHighlights();
          updateCount();
        }
      })
      .catch(function() {});
  }

  // ── Init modo selección ────────────────────────────────────────
  function init() {
    buildBar();
    maybeShowIntro();
    var found = scan();
    showNoBtnsMsg(found);

    if (firstActivation) loadFromBackend();

    new MutationObserver(function() {
      var f = scan();
      showNoBtnsMsg(f);
    }).observe(document.body, { childList: true, subtree: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

})();
</script>

